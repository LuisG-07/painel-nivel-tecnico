rules_version = '2';

// Regras do Firestore — SkillMatrix / GCK (app PUBLICADO na web)
// Acesso restrito a uma LISTA DE E-MAILS autorizados. A config web do Firebase
// é pública, então a segurança real vem daqui: só e-mails na allowlist leem/gravam.
// Para adicionar/remover pessoas, edite a lista e rode:
//   npx firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function autorizado() {
      return request.auth != null && request.auth.token.email in [
        // ⟶ e-mails (Google) autorizados — adicione/remova conforme necessário:
        "gustavo@clickdigital.com.br"
      ];
    }

    match /{document=**} {
      allow read, write: if autorizado();
    }
  }
}
