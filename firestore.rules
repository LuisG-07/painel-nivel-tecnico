rules_version = '2';

// Regras do Firestore — SkillMatrix / Painel Tecnico (app PUBLICADO na web).
// A config web do Firebase e publica; a seguranca real vem daqui.
//
// Acesso restrito a uma LISTA DE E-MAILS na colecao `allowedUsers` (editavel
// pela tela de admin — nao precisa republicar regras pra adicionar/remover).
// Somente admin (role == 'admin') gerencia usuarios e le os logs de auditoria.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function userEmail() { return request.auth.token.email; }
    function allowDoc()  { return get(/databases/$(database)/documents/allowedUsers/$(userEmail())); }

    function isAllowed() {
      return signedIn()
        && exists(/databases/$(database)/documents/allowedUsers/$(userEmail()));
    }
    function isAdmin() {
      return isAllowed() && allowDoc().data.role == 'admin';
    }

    // Lista de acesso — quem pode usar o painel. Admin gerencia pela tela.
    match /allowedUsers/{userDocEmail} {
      allow read:  if isAllowed();
      allow write: if isAdmin();
    }

    // Log de auditoria — so admin le; qualquer autorizado grava; imutavel.
    match /auditLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAllowed();
      allow update, delete: if false;
    }

    // Dados do painel (analistas, modulos, treinamentos, historico, config...).
    match /appData/{document=**} {
      allow read, write: if isAllowed();
    }
  }
}
