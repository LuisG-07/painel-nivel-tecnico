{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "site": "painel-tecnico-clickdigital",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "server.js",
      "package.json",
      "package-lock.json",
      "firestore.rules",
      "firestore.indexes.json",
      "*.md",
      "*.log",
      "serviceAccountKey.json",
      "*serviceAccount*.json",
      "*-firebase-adminsdk-*.json",
      "scripts/**",
      "start_server.ps1",
      "build.js",
      "build.ps1",
      "zd_import_data.js",
      "load_zendesk.html",
      "SkillMatrix_Pro.html",
      "dist/**"
    ],
    "rewrites": [
      { "source": "/zdproxy/**", "function": "zdproxy" }
    ]
  }
}
